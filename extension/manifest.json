{
  "manifest_version": 3,
  "name": "Understand This Paper — Equation Explainer",
  "version": "0.1.0",
  "description": "Turn any arXiv paper tab into a color-coded, grounded equation explainer. Free to use with your own LLM API key (bring-your-own-key beta).",
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Explain this paper's equations",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png" }
  },
  "background": { "service_worker": "sw.js", "type": "module" },
  "options_page": "options.html",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://arxiv.org/*",
    "https://alphaxiv.org/*",
    "https://www.alphaxiv.org/*",
    "https://huggingface.co/*",
    "https://api.anthropic.com/*",
    "https://api.openai.com/*",
    "https://openrouter.ai/*",
    "http://localhost/*"
  ]
}
